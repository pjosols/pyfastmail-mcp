"""Email thread tool."""

import json

from mcp.server.fastmcp import FastMCP

from ..client import USING_MAIL, JMAPClient

_THREAD_EMAIL_PROPS = ["id", "threadId", "subject", "from", "receivedAt", "preview"]


def register(server: FastMCP, client: JMAPClient) -> None:
    @server.tool()
    async def get_email_thread(email_id: str) -> str:
        """Return all emails in the same thread as the given email, in chronological order.

        Args:
            email_id: ID of any email in the thread.
        """
        try:
            account_id = client.account_id

            # Step 1: get the threadId from the email
            responses = client.call(
                USING_MAIL,
                [
                    [
                        "Email/get",
                        {
                            "accountId": account_id,
                            "ids": [email_id],
                            "properties": ["threadId"],
                        },
                        "g",
                    ]
                ],
            )
            _, data, _ = responses[0]
            items = data.get("list", [])
            if not items:
                return json.dumps({"error": f"Email {email_id!r} not found"})

            thread_id = items[0]["threadId"]

            # Step 2: query all emails in the thread, then get their details
            emails = client.query_and_get(
                "Email",
                {"threadId": thread_id},
                _THREAD_EMAIL_PROPS,
                sort=[{"property": "receivedAt", "isAscending": True}],
            )
            return json.dumps(emails, indent=2)
        except Exception as exc:
            return json.dumps({"error": str(exc)})

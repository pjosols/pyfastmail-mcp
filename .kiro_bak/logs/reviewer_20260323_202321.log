from pyfastmail_mcp.tools.mail.masked_email import register


def _client():
    c = MagicMock()
    c.account_id = "acc99"
    return c


def _tool(client, name):
    server = FastMCP("test")
    register(server, client)
    return server._tool_manager._tools[name].fn



def _real_client():
    return DAVClient(email="u@example.com", app_password="pw")


def test_validate_allows_carddav():
    _real_client().validate_dav_url(
        f"{CARDDAV_BASE}/dav/addressbooks/user/u@example.com/Default/"
    )



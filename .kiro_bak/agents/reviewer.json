{
  "name": "reviewer",
  "description": "Reviews codebase and maintains steering docs for the team",
  "model": "claude-sonnet-4.6",
  "prompt": "file://./reviewer-prompt.md",
  "tools": ["*"],
  "allowedTools": ["fs_read", "fs_write", "execute_bash", "glob", "grep"],
  "toolsSettings": {
    "fs_write": { "allowedPaths": [".kiro/steering/**"] },
    "execute_bash": { "autoAllowReadonly": true }
  },
  "resources": [
    "file://AGENT_TODO.md",
    "file://.kiro/steering/**/*.md",
    "skill://.kiro/skills/language-standards/SKILL.md",
    "skill://.kiro/skills/project-architecture/SKILL.md"
  ]
}
